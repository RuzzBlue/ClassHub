{
  "name": "classhub",
  "version": "1.0.0",
  "description": "ClassHub - Desktop course runtime and package manager",
  "main": "./out/main/index.js",
  "author": "ClassHub",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:ui": "electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package:demo": "node scripts/package-demo-course.js",
    "serve": "tsx --tsconfig tsconfig.node.json scripts/web-server.ts",
    "serve:full": "npm run build && npm run serve"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "adm-zip": "^0.5.16",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^4.22.2",
    "framer-motion": "^12.4.7",
    "i18next": "^24.2.2",
    "nanoid": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^7.2.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.0.9",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.classhub.app",
    "productName": "ClassHub",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "courses/**/*"
    ],
    "extraResources": [
      {
        "from": "courses",
        "to": "courses",
        "filter": [
          "**/*",
          "!**/*.zip"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
