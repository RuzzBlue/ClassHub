# Neon PostgreSQL — use the pooler host (recommended for ClassHub)
# ClassHub connects over the Neon serverless WebSocket driver (works in Electron + browser server).
DATABASE_URL=postgresql://USER:PASSWORD@ep-YOUR-PROJECT-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# First-run admin seed (only when users table is empty)
CLASSHUB_SEED_ADMIN_EMAIL=admin@classhub.local
CLASSHUB_SEED_ADMIN_PASSWORD=changeme
