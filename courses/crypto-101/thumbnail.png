<svg xmlns="http://www.w3.org/2000/svg" width="400" height="225" viewBox="0 0 400 225">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6c5ce7"/>
      <stop offset="100%" style="stop-color:#00cec9"/>
    </linearGradient>
  </defs>
  <rect width="400" height="225" fill="url(#bg)" rx="12"/>
  <text x="200" y="100" text-anchor="middle" fill="white" font-family="Segoe UI,sans-serif" font-size="28" font-weight="bold">Crypto 101</text>
  <text x="200" y="135" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-family="Segoe UI,sans-serif" font-size="14">Fundamentos de Blockchain</text>
  <text x="200" y="190" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-family="Segoe UI,sans-serif" font-size="12">ClassHub Demo Course</text>
</svg>
